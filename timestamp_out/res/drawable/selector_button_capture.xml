<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="false" android:state_pressed="true">
        <shape android:shape="ring" android:innerRadiusRatio="4.0" android:thicknessRatio="10.0" android:useLevel="false">
            <solid android:color="@color/ts_capture_button_pressed" />
        </shape>
    </item>
    <item android:state_selected="false" android:state_pressed="false">
        <shape android:shape="ring" android:innerRadiusRatio="4.0" android:thicknessRatio="10.0" android:useLevel="false">
            <solid android:color="@color/ts_capture_button_normal" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="ring" android:innerRadiusRatio="4.0" android:thicknessRatio="10.0" android:useLevel="false">
            <solid android:color="@color/ts_capture_button_pressed" />
        </shape>
    </item>
</selector>
